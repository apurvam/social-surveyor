# Session 2.5 note: Reddit is now RSS-based and needs NO credentials.
# The operator's Reddit username is set per-project in
# projects/<n>/sources/reddit.yaml (used to build a polite User-Agent),
# not here. The old REDDIT_CLIENT_ID / REDDIT_CLIENT_SECRET /
# REDDIT_USER_AGENT vars are only consulted by the dormant PRAW source
# in src/social_surveyor/sources/reddit_api.py and are not needed for
# normal operation.

# GitHub personal access token. No scopes required for public search.
# Create one at https://github.com/settings/tokens (classic or fine-grained).
GITHUB_TOKEN=

# X (Twitter) API v2 bearer token. Pay-per-use tier recommended.
# Generate one at https://developer.x.com/en/portal/dashboard.
X_BEARER_TOKEN=
